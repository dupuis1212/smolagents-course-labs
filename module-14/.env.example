# Copy to .env (never commit .env). Quill reads these from the environment; never hard-code keys.

# --- Default backend (QUILL_MODEL_BACKEND=hf) ---
# Create a FINE-GRAINED token at https://huggingface.co/settings/tokens with the
# "Make calls to Inference Providers" scope. The free tier is ~$0.10/mo of routed credits
# (as of smolagents 1.26.0, subject to change) — a multi-step CodeAgent burns that fast.
# M9: HF_TOKEN is ALSO what `push_save_chart --push` uses to publish save_chart to the Hub
# (the token needs WRITE access for that) and what the MCP demo's model calls use.
# M13: HF_TOKEN (WRITE scope) is REQUIRED for `python -m quill.publish --repo <user>/quill`
# (agent.push_to_hub) and for reloading with CodeAgent.from_hub. A pushed agent PUBLISHES its tool
# code — never embed a secret in a tool; use `--private` for a private repo (C7).
HF_TOKEN=hf_xxx

# --- MCP (Module 9): no key needed, but `uvx` must be on PATH ---
# Quill connects to a stdio MCP data server launched with `uvx mcp-server-sqlite --db-path
# data/sales.db`. `uvx` ships with `uv` (check: `uvx --version`). Build the DB first:
#   uv run python -m quill.scripts.build_sales_db
# trust_remote_code=True is REQUIRED to run MCP/Hub tools — a stdio server executes code on your
# machine, so only connect to servers you trust (the interop security gate; see M5's threat model).

# --- Swap the model in ONE place — no agent-code edit (quill/config.py::make_model) ---
# QUILL_MODEL_BACKEND ∈ {hf, litellm, local}  (default: hf)
# QUILL_MODEL_ID      backend-specific model id (default: Qwen/Qwen2.5-Coder-32B-Instruct)
#
# Hugging Face Inference Providers (default):
#   QUILL_MODEL_BACKEND=hf
#   QUILL_MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct
#
# A hosted frontier model via LiteLLM ("<provider>/<model>"; needs that provider's key below):
#   QUILL_MODEL_BACKEND=litellm
#   QUILL_MODEL_ID=gpt-4o            # or anthropic/claude-3-5-sonnet-latest, gemini/gemini-1.5-pro
#
# A local model via Ollama (served at localhost:11434; num_ctx is raised to 8192 for you):
#   QUILL_MODEL_BACKEND=local
#   QUILL_MODEL_ID=ollama_chat/llama3.2

# --- Vision (Module 11): point make_model at a VLM to re-read charts / drive the vision browser ---
# Image input depends ONLY on the model being a VLM (vision-language model) — NO extra is needed
# for `--review` (the [vision] extra is a BROWSER, not image input). Set a VLM model_id:
#   QUILL_MODEL_ID=Qwen/Qwen2-VL-72B-Instruct       # via the hf backend (re-verify availability)
# or a hosted VLM via LiteLLM (needs OPENAI_API_KEY below):
#   QUILL_MODEL_BACKEND=litellm
#   QUILL_MODEL_ID=gpt-4o
# The optional `--browse` vision_browser ALSO needs `pip install 'smolagents[vision]'` + a local Chrome.

# --- Optional provider keys (only needed for QUILL_MODEL_BACKEND=litellm) ---
# OPENAI_API_KEY=sk_xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# GEMINI_API_KEY=xxx

# --- Sandbox: where Quill's generated Python runs (quill/sandbox.py::resolve_executor) ---
# QUILL_EXECUTOR ∈ {local, docker, e2b}  (default: local)
#   local  : in-process LocalPythonExecutor (instant, free, NOT a security sandbox)
#   docker : a local Docker container (real isolation; needs the [docker] extra + a daemon)
#   e2b    : an E2B cloud microVM (needs the [e2b] extra + E2B_API_KEY below)
# Note: "wasm" was REMOVED in smolagents 1.26.0 — it is not a valid value.
#   QUILL_EXECUTOR=docker

# Only needed for QUILL_EXECUTOR=e2b — sign up at https://e2b.dev (free tier).
# E2B_API_KEY=e2b_xxx

# --- Telemetry (Module 14): trace Quill with OpenTelemetry/OpenInference ---
# quill/telemetry.py calls SmolagentsInstrumentor().instrument() BEFORE the agent is built (06 §2).
# QUILL_TELEMETRY ∈ {none, langfuse, phoenix}  (default: none = a clean no-op; a run with no backend
# is never broken). Telemetry semantic conventions are still evolving as of smolagents 1.26.0.
#   QUILL_TELEMETRY=none
#
# Langfuse (hosted cloud or self-host). EU = https://cloud.langfuse.com, US = https://us.cloud.langfuse.com.
# A Langfuse-only setup can `pip install openinference-instrumentation-smolagents langfuse` (no arize-phoenix).
#   QUILL_TELEMETRY=langfuse
#   LANGFUSE_PUBLIC_KEY=pk-lf-xxx
#   LANGFUSE_SECRET_KEY=sk-lf-xxx
#   LANGFUSE_HOST=https://cloud.langfuse.com
#
# Arize Phoenix (local collector). Start it first: `python -m phoenix.server.main serve`
# (UI at http://0.0.0.0:6006/projects/). The [telemetry] extra pulls arize-phoenix.
#   QUILL_TELEMETRY=phoenix
#
# ⚠️ Traces capture prompts AND data (the user's CSV may leave for a cloud backend) — in production,
# self-host Langfuse/Phoenix or mask sensitive inputs.

# --- Eval harness (Module 14): score Quill behind a regression gate ---
# `uv run python -m quill.eval.run_evals --out eval/results/run-baseline.json`
# The LLM-as-judge uses a SEPARATE model (never self-grading) via make_model — point it at a
# different/stronger model than Quill (ideally). One eval run = N Quill runs + N judge calls, and the
# judge ALSO costs tokens, so a multi-step golden set burns the HF free tier ($0.10/mo) fast.
#   QUILL_JUDGE_MODEL_ID=Qwen/Qwen2.5-72B-Instruct   # the judge's model (defaults to Quill's if unset)
# The regression gate thresholds (the harness exits non-zero when either is crossed — CI-usable):
#   QUILL_EVAL_MIN_TSR=0.70        # minimum Task Success Rate (default 0.70)
#   QUILL_EVAL_MAX_COST=20000      # max cost/run in tokens (default: off / no cost cap)
